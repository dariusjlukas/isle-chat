# Copy to .env and fill in. .env is gitignored.
# Database
POSTGRES_USER=chatapp
POSTGRES_PASSWORD=CHANGEME_generate_with_openssl_rand_hex_32
POSTGRES_DB=chatapp

# Backend tuning
SESSION_EXPIRY_HOURS=168
PUBLIC_URL=
MAX_FILE_SIZE=0
DB_POOL_SIZE=10

# Optional Redis URL for horizontal WS scaling. When set, all backend
# instances must point at the same Redis. Empty = single-instance mode.
# Bring up the redis service with `docker compose --profile redis up`.
# REDIS_URL=redis://redis:6379

# Optional: stable per-instance ID. Used to filter out the instance's own
# Redis-published messages. Defaults to a random UUID at boot. For sticky
# multi-instance deployments set this to e.g. ${HOSTNAME}.
# INSTANCE_ID=
